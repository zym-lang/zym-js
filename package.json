{
  "name": "@zym-lang/zym-js",
  "version": "0.3.0-alpha.2",
  "description": "JavaScript / WebAssembly bindings for the Zym scripting language. Embed a Zym VM in Node, the browser, or a Web Worker — compile and run scripts, register JS functions as Zym natives, define globals, save/load bytecode, and call script functions from JS.",
  "type": "module",
  "main": "./js/zym.mjs",
  "module": "./js/zym.mjs",
  "types": "./js/zym.d.ts",
  "exports": {
    ".": {
      "types": "./js/zym.d.ts",
      "import": "./js/zym.mjs",
      "default": "./js/zym.mjs"
    },
    "./wasm": "./dist/zym_js.wasm",
    "./package.json": "./package.json"
  },
  "files": [
    "js/zym.mjs",
    "js/zym.d.ts",
    "dist/zym_js.mjs",
    "dist/zym_js.wasm",
    "doc.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "cmake --build cmake-build-wasm --target zym_js",
    "test": "npm run test:smoke && npm run test:regressions",
    "test:smoke": "node test/node-smoke.mjs",
    "test:regressions": "node test/run-core-tests.mjs",
    "test:raw": "node test/run-core-tests-raw.mjs"
  },
  "keywords": [
    "zym",
    "zym-lang",
    "scripting",
    "language",
    "vm",
    "wasm",
    "webassembly",
    "embed",
    "sandbox",
    "interpreter"
  ],
  "author": "Dawson Pate (Anatole DP)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zym-lang/zym-js.git"
  },
  "bugs": {
    "url": "https://github.com/zym-lang/zym-js/issues"
  },
  "homepage": "https://github.com/zym-lang/zym-js#readme",
  "engines": {
    "node": ">=16"
  },
  "sideEffects": false
}
