var combo_result2 = combo_function(5)
assert_wrap(combo_result1() == 0, "26.1: Combo function 0 args")
assert_wrap(combo_result2() == 5, "26.2: Combo function 1 arg first call")
assert_wrap(combo_result2() == 10, "26.3: Combo function 1 arg second call")

func combo_function() {
    var x = 0
    return func () {
        return x
    }
}

func combo_function(start) {
    var x = start
    return func () {
        var temp = x
        x = x + start
        return temp
    }
}


