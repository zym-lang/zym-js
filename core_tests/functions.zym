// ============================================================================
// SECTION 33: CLOSURE ALIASING
// ============================================================================
print("--- [33] Closure Aliasing ---")

func aliasTest() {
    var shared = 0

    func inc1() {
        shared = shared + 1
        return shared
    }

    func inc2() {
        shared = shared + 2
        return shared
    }

    return func (choice) {
        if (choice == 1) return inc1()
        return inc2()
    }
}

var alias = aliasTest()
assert_wrap(alias(1) == 1, "33.1: Alias inc1 first")
assert_wrap(alias(2) == 3, "33.2: Alias inc2")
assert_wrap(alias(1) == 4, "33.3: Alias inc1 second")
assert_wrap(alias(2) == 6, "33.4: Alias inc2 second")


