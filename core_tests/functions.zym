// ============================================================================
// SECTION 22: CLOSURE WITH OVERLOADED NESTED FUNCTIONS
// ============================================================================
print("--- [22] Closure with Overloaded Nested Functions ---")

func closureOverloadFactory() {
    var base = 100

    func operation() {
        return base
    }

    func operation(x) {
        return base + x
    }

    func operation(x, y) {
        return base + x + y
    }

    return func (a, b) {
        if (a == 0) return operation()
        if (b == 0) return operation(a)
        return operation(a, b)
    }
}

var cop = closureOverloadFactory()
assert_wrap(cop(0, 0) == 100, "22.1: Nested overload 0 args")
assert_wrap(cop(50, 0) == 150, "22.2: Nested overload 1 arg")
assert_wrap(cop(20, 30) == 150, "22.3: Nested overload 2 args")


// ============================================================================
// SECTION 23: RECURSION WITH CLOSURES
// ============================================================================
print("--- [23] Recursive Closures ---")

func makeFibonacci() {
    func fib(n) {
        if (n <= 1) return n
        return fib(n - 1) + fib(n - 2)
    }
    return fib
}

var fibonacci = makeFibonacci()
assert_wrap(fibonacci(0) == 0, "23.1: Fibonacci(0)")
assert_wrap(fibonacci(1) == 1, "23.2: Fibonacci(1)")
assert_wrap(fibonacci(5) == 5, "23.3: Fibonacci(5)")
assert_wrap(fibonacci(7) == 13, "23.4: Fibonacci(7)")


// ============================================================================
// SECTION 24: ANONYMOUS RECURSIVE FUNCTIONS
// ============================================================================
print("--- [24] Anonymous Recursive Functions ---")

var factorial
factorial = func (n) {
    if (n <= 1) return 1
    return n * factorial(n - 1)
}

assert_wrap(factorial(5) == 120, "24.1: Factorial(5)")
assert_wrap(factorial(6) == 720, "24.2: Factorial(6)")


// ============================================================================
// SECTION 25: COMPLEX CLOSURE CHAINS WITH MUTATIONS
// ============================================================================
print("--- [25] Complex Closure Chains with State Mutation ---")

func createStateMachine(initial) {
    var state = initial
    var history = 0

    func get() {
        return state
    }

    func set(value) {
        history = state
        state = value
    }

    func revert() {
        var temp = state
        state = history
        history = temp
    }

    func getHistory() {
        return history
    }

    return func (action) {
        if (action == "get") return get()
        if (action == "history") return getHistory()
        return state
    }
}

var sm = createStateMachine(10)
assert_wrap(sm("get") == 10, "25.1: State machine get")


