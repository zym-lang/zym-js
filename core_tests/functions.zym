// ============================================================================
// SECTION 29: SHADOWING WITH CLOSURES
// ============================================================================
print("--- [29] Shadowing with Closures ---")

func shadowTest() {
    var x = 10

    func inner() {
        var x = 20
        func innermost() {
            var x = 30
            return x
        }
        return innermost() + x
    }

    return inner() + x
}

assert_wrap(shadowTest() == 60, "29.1: Shadowing (30 + 20 + 10)")


// ============================================================================
// SECTION 30: EARLY RETURNS IN CLOSURES
// ============================================================================
print("--- [30] Early Returns in Closures ---")

func makeValidator(threshold) {
    return func (value) {
        if (value < 0) return "negative"
        if (value == 0) return "zero"
        if (value < threshold) return "below threshold"
        return "above threshold"
    }
}

var validate = makeValidator(10)
assert_wrap(validate(-5) == "negative", "30.1: Validator negative")
assert_wrap(validate(0) == "zero", "30.2: Validator zero")
assert_wrap(validate(5) == "below threshold", "30.3: Validator below")
assert_wrap(validate(15) == "above threshold", "30.4: Validator above")


