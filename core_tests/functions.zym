// ============================================================================
// SECTION 38: DEEPLY NESTED WITH MIXED TYPES
// ============================================================================
print("--- [38] Deeply Nested Mixed Function Types ---")

func deepMixed() {
    var a = 1

    var f1 = func () {
        var b = 2

        return (x) => {
            var c = 3

            func inner() {
                return a + b + c + x
            }

            return inner
        }
    }

    return f1
}

var dm1 = deepMixed()
var dm2 = dm1()
var dm3 = dm2(4)
assert_wrap(dm3() == 10, "38.1: Deeply nested mixed (1+2+3+4)")


// ============================================================================
// SECTION 39: CLOSURE WITH CONDITIONAL LOGIC
// ============================================================================
print("--- [39] Closure with Conditional Logic ---")

func makeConditionalClosure(threshold) {
    var count = 0

    return func (value) {
        count = count + 1
        if (value > threshold) {
            return count
        }
        return 0
    }
}

var conditional = makeConditionalClosure(10)
assert_wrap(conditional(5) == 0, "39.1: Conditional below threshold")
assert_wrap(conditional(15) == 2, "39.2: Conditional above threshold count 2")
assert_wrap(conditional(8) == 0, "39.3: Conditional below threshold again")
assert_wrap(conditional(20) == 4, "39.4: Conditional above threshold count 4")


// ============================================================================
// SECTION 40: FINAL COMPREHENSIVE TEST
// ============================================================================
print("--- [40] Final Comprehensive Test ---")

var final_test = comprehensive(5)
assert_wrap(final_test() == 10, "40.1: Comprehensive overload 1 arg")

func comprehensive(x) {
    var captured = x
    return func () {
        captured = captured + 5
        return captured
    }
}

func comprehensive(x, y) {
    var captured = x + y
    return (z) => {
        captured = captured * z
        return captured
    }
}

var final_test2 = comprehensive(3, 4)
assert_wrap(final_test2(2) == 14, "40.2: Comprehensive overload 2 args (7*2)")


// ============================================================================
// SECTION 41: OVERLOADED CLOSURE FACTORIES (PROPER PATTERN)
// ============================================================================
print("--- [41] Overloaded Closure Factories ---")

func makeGreeter() {
    var greeting = "Hello"
    func greet(name) {
        return greeting + ", " + name
    }
    return greet
}

func makeGreeter(customGreeting) {
    var greeting = customGreeting
    func greet(name) {
        return greeting + ", " + name
    }
    return greet
}

var defaultGreeter = makeGreeter()
var customGreeter = makeGreeter("Howdy")

assert_wrap(defaultGreeter("World") == "Hello, World", "41.1: Default greeter")
assert_wrap(customGreeter("Partner") == "Howdy, Partner", "41.2: Custom greeter")


// ============================================================================
// SECTION 42: HOISTED OVERLOADED CLOSURE FACTORIES
// ============================================================================
print("--- [42] Hoisted Overloaded Closure Factories ---")

var hoist_g1 = hoistedGreeterFactory()
var hoist_g2 = hoistedGreeterFactory("Greetings")

assert_wrap(hoist_g1("Alice") == "Hi, Alice", "42.1: Hoisted greeter default")
assert_wrap(hoist_g2("Bob") == "Greetings, Bob", "42.2: Hoisted greeter custom")

func hoistedGreeterFactory() {
    var msg = "Hi"
    func doGreet(name) {
        return msg + ", " + name
    }
    return doGreet
}

func hoistedGreeterFactory(message) {
    var msg = message
    func doGreet(name) {
        return msg + ", " + name
    }
    return doGreet
}


// ============================================================================
// SECTION 43: CLOSURE FACTORY RETURNING MULTIPLE CLOSURES VIA GLOBALS
// ============================================================================
print("--- [43] Multiple Closures via Global Assignment ---")

var reader43
var writer43
var counter43

func setupMultiClosures(initial) {
    var value = initial
    var count = 0

    reader43 = func () {
        return value
    }

    writer43 = func (v) {
        value = v
        count = count + 1
    }

    counter43 = func () {
        return count
    }
}

setupMultiClosures(1000)
assert_wrap(reader43() == 1000, "43.1: Multi closure reader")
writer43(2000)
assert_wrap(reader43() == 2000, "43.2: Multi closure after write")
assert_wrap(counter43() == 1, "43.3: Multi closure counter")


// ============================================================================
// SECTION 44: CLOSURE WITH MULTIPLE OVERLOADED NESTED FUNCTIONS
// ============================================================================
print("--- [44] Multiple Overloaded Functions in Closure ---")

func complexFactory(base) {
    func add() {
        return base
    }

    func add(x) {
        return base + x
    }

    func multiply() {
        return base
    }

    func multiply(x) {
        return base * x
    }

    return func (operation, arg) {
        if (operation == "add") {
            if (arg == 0) return add()
            return add(arg)
        }
        if (arg == 0) return multiply()
        return multiply(arg)
    }
}

var cf = complexFactory(10)
assert_wrap(cf("add", 0) == 10, "44.1: Complex factory add 0")
assert_wrap(cf("add", 5) == 15, "44.2: Complex factory add 5")
assert_wrap(cf("multiply", 0) == 10, "44.3: Complex factory multiply 0")
assert_wrap(cf("multiply", 3) == 30, "44.4: Complex factory multiply 3")


// ============================================================================
// SECTION 45: DEEPLY NESTED CLOSURES WITH OVERLOADING
// ============================================================================
print("--- [45] Deeply Nested with Overloading ---")

func level1Factory() {
    var l1 = 1

    func level2Factory() {
        var l2 = 10

        func level3Factory() {
            var l3 = 100

            func compute() {
                return l1 + l2 + l3
            }

            func compute(x) {
                return l1 + l2 + l3 + x
            }

            return func (value) {
                if (value == 0) return compute()
                return compute(value)
            }
        }

        return level3Factory
    }

    return level2Factory
}

var lf1 = level1Factory()
var lf2 = lf1()
var lf3 = lf2()
assert_wrap(lf3(0) == 111, "45.1: Deep nested overload 0")
assert_wrap(lf3(9) == 120, "45.2: Deep nested overload 9")


// ============================================================================
// SECTION 46: CLOSURE CAPTURING OVERLOADED FUNCTION RESULTS
// ============================================================================
print("--- [46] Closure Capturing Overloaded Results ---")

func provider() {
    return 100
}

func provider(x) {
    return 100 + x
}

func provider(x, y) {
    return 100 + x + y
}

func captureResults() {
    var r0 = provider()
    var r1 = provider(10)
    var r2 = provider(5, 15)

    return func (which) {
        if (which == 0) return r0
        if (which == 1) return r1
        return r2
    }
}

var results = captureResults()
assert_wrap(results(0) == 100, "46.1: Captured result 0 args")
assert_wrap(results(1) == 110, "46.2: Captured result 1 arg")
assert_wrap(results(2) == 120, "46.3: Captured result 2 args")


// ============================================================================
// SECTION 47: ANONYMOUS OVERLOADED FACTORIES
// ============================================================================
print("--- [47] Anonymous Overloaded Factory Pattern ---")

var anonFactory0 = func () {
    var state = "zero"
    return func () { return state }
}

var anonFactory1 = func (s) {
    var state = s
    return func () { return state }
}

var af0 = anonFactory0()
var af1 = anonFactory1("custom")
assert_wrap(af0() == "zero", "47.1: Anonymous factory 0")
assert_wrap(af1() == "custom", "47.2: Anonymous factory 1")


