// ============================================================================
// FULL COVERAGE FUNCTION TEST FILE
// Tests: Hoisting, Overloading (by arity), Closures, Anonymous Functions
// ============================================================================

// Test helper function
var testsPassed = 0
var testsFailed = 0

func assert_wrap(condition, testName) {
    if (condition) {
        testsPassed = testsPassed + 1
    } else {
        testsFailed = testsFailed + 1
        print("FAILED: ")
        print(testName)
        print("")
    }
}

print("=== STARTING FULL COVERAGE FUNCTION TESTS ===")
print("")

// ============================================================================
// SECTION 1: FUNCTION HOISTING
// ============================================================================
print("--- [1] Basic Hoisting ---")

// Call before definition
var hoisted_result = hoisted_add(10, 20)
assert_wrap(hoisted_result == 30, "1.1: Hoisted function call before definition")

func hoisted_add(a, b) {
    return a + b
}

// Call after definition to confirm
assert_wrap(hoisted_add(5, 15) == 20, "1.2: Hoisted function call after definition")


// ============================================================================
// SECTION 2: OVERLOADING BY ARITY
// ============================================================================
print("--- [2] Basic Overloading ---")

func process() {
    return "No arguments"
}

func process(x) {
    return x * 2
}

func process(x, y) {
    return x + y
}

func process(x, y, z) {
    return x + y + z
}

assert_wrap(process() == "No arguments", "2.1: Overload with 0 args")
assert_wrap(process(5) == 10, "2.2: Overload with 1 arg")
assert_wrap(process(3, 7) == 10, "2.3: Overload with 2 args")
assert_wrap(process(1, 2, 3) == 6, "2.4: Overload with 3 args")


// ============================================================================
// SECTION 3: HOISTING + OVERLOADING
// ============================================================================
print("--- [3] Hoisting with Overloading ---")

// Call overloaded functions before definition
assert_wrap(compute() == 0, "3.1: Hoisted overload 0 args")
assert_wrap(compute(10) == 100, "3.2: Hoisted overload 1 arg")
assert_wrap(compute(5, 3) == 15, "3.3: Hoisted overload 2 args")

func compute() {
    return 0
}

func compute(x) {
    return x * x
}

func compute(x, y) {
    return x * y
}


// ============================================================================
// SECTION 4: BASIC CLOSURES
// ============================================================================
print("--- [4] Basic Closure with Single Captured Variable ---")

func makeCounter() {
    var count = 0
    func increment() {
        count = count + 1
        return count
    }
    return increment
}

var counter1 = makeCounter()
assert_wrap(counter1() == 1, "4.1: First counter call")
assert_wrap(counter1() == 2, "4.2: Second counter call")
assert_wrap(counter1() == 3, "4.3: Third counter call")

var counter2 = makeCounter()
assert_wrap(counter2() == 1, "4.4: New counter starts at 1")
assert_wrap(counter1() == 4, "4.5: First counter continues at 4")


// ============================================================================
// SECTION 5: CLOSURES WITH MULTIPLE CAPTURED VARIABLES
// ============================================================================
print("--- [5] Closure with Multiple Captured Variables ---")

func makeAccumulator(initial) {
    var sum = initial
    var count = 0
    func add(value) {
        sum = sum + value
        count = count + 1
        return sum
    }
    return add
}

var acc = makeAccumulator(100)
assert_wrap(acc(5) == 105, "5.1: Accumulator add 5")
assert_wrap(acc(10) == 115, "5.2: Accumulator add 10")
assert_wrap(acc(20) == 135, "5.3: Accumulator add 20")


// ============================================================================
// SECTION 6: NESTED CLOSURES (DEPTH 2)
// ============================================================================
print("--- [6] Nested Closures Depth 2 ---")

func outer(x) {
    func middle(y) {
        func inner(z) {
            return x + y + z
        }
        return inner
    }
    return middle
}

var level1 = outer(10)
var level2 = level1(20)
assert_wrap(level2(30) == 60, "6.1: Nested closure depth 2")


// ============================================================================
// SECTION 7: NESTED CLOSURES (DEPTH 3)
// ============================================================================
print("--- [7] Nested Closures Depth 3 ---")

func deepOuter() {
    var a = 1
    func deepMiddle() {
        var b = 2
        func deepInner() {
            var c = 3
            func deepest() {
                return a + b + c
            }
            return deepest
        }
        return deepInner
    }
    return deepMiddle
}

var d1 = deepOuter()
var d2 = d1()
var d3 = d2()
assert_wrap(d3() == 6, "7.1: Nested closure depth 3")


// ============================================================================
// SECTION 8: SHARED UPVALUES BETWEEN SIBLING CLOSURES
// ============================================================================
print("--- [8] Shared Upvalues Between Siblings ---")

var getter
var setter
var incrementer

func setupShared() {
    var shared = 0
    func get() {
        return shared
    }
    func set(value) {
        shared = value
    }
    func inc() {
        shared = shared + 1
        return shared
    }
    getter = get
    setter = set
    incrementer = inc
}

setupShared()
assert_wrap(getter() == 0, "8.1: Shared upvalue initial")
setter(50)
assert_wrap(getter() == 50, "8.2: Shared upvalue after set")
assert_wrap(incrementer() == 51, "8.3: Shared upvalue increment to 51")
assert_wrap(incrementer() == 52, "8.4: Shared upvalue increment to 52")
assert_wrap(getter() == 52, "8.5: Shared upvalue final")


// ============================================================================
// SECTION 9: PARAMETER CAPTURE IN CLOSURES
// ============================================================================
print("--- [9] Parameter Capture ---")

func makeMultiplier(factor) {
    func multiply(value) {
        return value * factor
    }
    return multiply
}

var times3 = makeMultiplier(3)
var times5 = makeMultiplier(5)
assert_wrap(times3(10) == 30, "9.1: Multiplier with factor 3")
assert_wrap(times5(10) == 50, "9.2: Multiplier with factor 5")


