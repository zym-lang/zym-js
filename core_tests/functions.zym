// ============================================================================
// SECTION 49: CLOSURE CHAIN WITH OVERLOADED INTERMEDIATES
// ============================================================================
print("--- [49] Closure Chain with Overloaded Steps ---")

func chainStart() {
    var a = 1

    func chainMiddle() {
        var b = 10

        func chainEnd() {
            return a + b
        }

        func chainEnd(x) {
            return a + b + x
        }

        return func (value) {
            if (value == 0) return chainEnd()
            return chainEnd(value)
        }
    }

    func chainMiddle(offset) {
        var b = 10 + offset

        func chainEnd() {
            return a + b
        }

        func chainEnd(x) {
            return a + b + x
        }

        return func (value) {
            if (value == 0) return chainEnd()
            return chainEnd(value)
        }
    }

    return chainMiddle
}

var cs = chainStart()
var cm1 = cs()
var cm2 = cs(5)
assert_wrap(cm1(0) == 11, "49.1: Chain 0 offset, 0 arg")
assert_wrap(cm1(100) == 111, "49.2: Chain 0 offset, 100 arg")
assert_wrap(cm2(0) == 16, "49.3: Chain 5 offset, 0 arg")
assert_wrap(cm2(100) == 116, "49.4: Chain 5 offset, 100 arg")


// ============================================================================
// SECTION 50: ULTIMATE COMPREHENSIVE TEST
// ============================================================================
print("--- [50] Ultimate Comprehensive Integration ---")

var ultimate1 = ultimateFactory(10)
var ultimate2 = ultimateFactory(20, 30)

assert_wrap(ultimate1("get") == 10, "50.1: Ultimate 1 arg get")
assert_wrap(ultimate1("double") == 20, "50.2: Ultimate 1 arg double")
assert_wrap(ultimate2("get") == 50, "50.3: Ultimate 2 args get")
assert_wrap(ultimate2("add") == 80, "50.4: Ultimate 2 args add")

func ultimateFactory(x) {
    var state = x

    func transform() {
        return state
    }

    func transform(op) {
        if (op == "double") return state * 2
        return state
    }

    return func (cmd) {
        if (cmd == "get") return transform()
        return transform(cmd)
    }
}

func ultimateFactory(x, y) {
    var state = x + y

    func transform() {
        return state
    }

    func transform(op) {
        if (op == "add") return state + y
        return state
    }

    return func (cmd) {
        if (cmd == "get") return transform()
        return transform(cmd)
    }
}


