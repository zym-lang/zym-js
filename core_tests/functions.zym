// ============================================================================
// SECTION 35: CLOSURE FACTORIES WITH OVERLOADING
// ============================================================================
print("--- [35] Closure Factories with Overloading ---")

func makeCalculator() {
    var memory = 0

    func calc(x) {
        memory = x
        return memory
    }

    func calc(x, y) {
        memory = x + y
        return memory
    }

    func calc(x, y, z) {
        memory = x + y + z
        return memory
    }

    return func (a, b, c) {
        if (c > 0) return calc(a, b, c)
        if (b > 0) return calc(a, b)
        return calc(a)
    }
}

var calculator = makeCalculator()
assert_wrap(calculator(10, 0, 0) == 10, "35.1: Calculator 1 arg")
assert_wrap(calculator(5, 7, 0) == 12, "35.2: Calculator 2 args")
assert_wrap(calculator(1, 2, 3) == 6, "35.3: Calculator 3 args")


