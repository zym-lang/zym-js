// ============================================================================
// COMPREHENSIVE MULTIPLE VARIABLE DECLARATION TEST SUITE
// This test covers the "var a, b = 1, c = d" syntax
// ============================================================================

// Test helper function
var testsPassed = 0
var testsFailed = 0

func assert_wrap(condition, message) {
    if (condition) {
        testsPassed = testsPassed + 1
    } else {
        testsFailed = testsFailed + 1
        print("FAILED: %s", message)
    }
}

print("==========================================================")
print("COMPREHENSIVE MULTIPLE VARIABLE DECLARATION TEST SUITE")
print("==========================================================")
print("")

// ============================================================================
// SECTION 1: GLOBAL MULTIPLE DECLARATIONS
// ============================================================================
print("=== SECTION 1: Global Multiple Declarations ===")

var g1, g2 = 10, g3 = 20 + 5
assert_wrap(g1 == null, "1.1: Uninitialized global is null")
assert_wrap(g2 == 10, "1.2: Initialized global value")
assert_wrap(g3 == 25, "1.3: Global initialized with expression")

var g4 = 100, g5 = "hello", g6 = g4 + 1
assert_wrap(g4 == 100, "1.4: Global with type specifier (number)")
assert_wrap(g5 == "hello", "1.5: Global with type specifier (string)")
assert_wrap(g6 == 101, "1.6: Global referencing previous declaration on same line")

// ============================================================================
// SECTION 2: LOCAL MULTIPLE DECLARATIONS
// ============================================================================
print("=== SECTION 2: Local Multiple Declarations ===")

func test_locals() {
    var l1, l2 = "world", l3 = 3.14
    assert_wrap(l1 == null, "2.1: Uninitialized local is null")
    assert_wrap(l2 == "world", "2.2: Initialized local value")
    assert_wrap(l3 == 3.14, "2.3: Local initialized with float")

    {
        var inner1 = 1, inner2 = 2, inner3 = inner1 + inner2
        assert_wrap(inner3 == 3, "2.4: Inner block multiple declarations")
    }
}
test_locals()

// ============================================================================
// SECTION 4: FOR LOOP INITIALIZATION
// ============================================================================
print("=== SECTION 4: For Loop Initialization ===")

var for_sum = 0
var last_j = 0
for (var i = 0, j = 10; i < 5; i++) {
    for_sum = for_sum + i
    last_j = j
    j = j + 1
}
assert_wrap(for_sum == 10, "4.1: for loop with multiple initializers (sum)")
assert_wrap(last_j == 14, "4.2: for loop with multiple initializers (j)")

// ============================================================================
// SECTION 5: CLOSURE CAPTURE
// ============================================================================
print("=== SECTION 5: Closure Capture ===")

func test_closure_capture() {
    var a = 1, b = 2, c = 3
    var f = func() {
        return a + b + c
    }
    assert_wrap(f() == 6, "5.1: Closure captures multiple declared variables")
    
    a = 10
    b = 20
    assert_wrap(f() == 33, "5.2: Closure reflects updates to captured variables")
}
test_closure_capture()

// ============================================================================
// SUMMARY
// ============================================================================
print("")
print("==========================================================")
print("TEST SUMMARY")
print("Tests Passed: %n", testsPassed)
print("Tests Failed: %n", testsFailed)
print("==========================================================")

if (testsFailed == 0) {
    print("ALL TESTS PASSED")
} else {
    print("SOME TESTS FAILED")
}
