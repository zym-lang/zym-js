// ============================================================================
// TAIL CALL OPTIMIZATION TEST SUITE
// Tests TCO with various patterns to verify O(1) stack usage
// ============================================================================

// Test helper function
var testsPassed = 0
var testsFailed = 0

func assert_wrap(condition, message) {
    if (condition) {
        testsPassed = testsPassed + 1
    } else {
        testsFailed = testsFailed + 1
        print("FAILED: " + message)
    }
}

print("=== STARTING FULL COVERAGE FUNCTION TESTS ===")
print("")

// ============================================================================
// TEST 1: Simple Tail Recursive Factorial with Accumulator
// ============================================================================
print("--- [1] Tail Recursive Factorial ---")

func factorial(n, acc) {
    if (n <= 1) {
        return acc
    }
    return factorial(n - 1, n * acc)
}

assert_wrap(factorial(5, 1) == 120, "1.1: Tail recursive factorial - 5!")
assert_wrap(factorial(10, 1) == 3628800, "1.2: Tail recursive factorial - 10!")

// ============================================================================
// TEST 2: Deep Recursion (Tests O(1) Stack Usage)
// ============================================================================
print("--- [2] Deep Recursion Countdown ---")

func countdown(n) {
    if (n <= 0) {
        return n
    }
    return countdown(n - 1)
}

assert_wrap(countdown(1000) == 0, "2.1: Deep recursion countdown - 1000 (no stack overflow)")

// ============================================================================
// TEST 3: Tail Recursive Sum
// ============================================================================
print("--- [3] Tail Recursive Sum ---")

func sum(n, acc) {
    if (n <= 0) {
        return acc
    }
    return sum(n - 1, acc + n)
}

assert_wrap(sum(10, 0) == 55, "3.1: Tail recursive sum - 1 to 10")
assert_wrap(sum(100, 0) == 5050, "3.2: Tail recursive sum - 1 to 100")

// ============================================================================
// TEST 4: Mutual Tail Recursion (Even/Odd)
// ============================================================================
print("--- [4] Mutual Tail Recursion ---")

func isEven(n) {
    if (n == 0) {
        return true
    }
    return isOdd(n - 1)
}

func isOdd(n) {
    if (n == 0) {
        return false
    }
    return isEven(n - 1)
}

assert_wrap(isEven(0) == true, "4.1: Mutual recursion - isEven(0)")
assert_wrap(isEven(1) == false, "4.2: Mutual recursion - isEven(1)")
assert_wrap(isEven(10) == true, "4.3: Mutual recursion - isEven(10)")
assert_wrap(isOdd(0) == false, "4.4: Mutual recursion - isOdd(0)")
assert_wrap(isOdd(1) == true, "4.5: Mutual recursion - isOdd(1)")
assert_wrap(isOdd(11) == true, "4.6: Mutual recursion - isOdd(11)")

// ============================================================================
// TEST 5: Tail Call with Closure Capture
// ============================================================================
print("--- [5] Tail Call with Closure ---")

func makeCounter(start) {
    func count(n, limit) {
        if (n >= limit) {
            return n
        }
        return count(n + start, limit)
    }
    return count
}

var counter = makeCounter(2)
assert_wrap(counter(0, 10) == 10, "5.1: Tail call with closure - count by 2s to 10")

// ============================================================================
// TEST 6: Non-Tail Recursive Fibonacci (Should Still Work)
// ============================================================================
print("--- [6] Non-Tail Recursive Fibonacci ---")

func fibonacci(n) {
    if (n <= 1) {
        return n
    }
    return fibonacci(n - 1) + fibonacci(n - 2)
}

assert_wrap(fibonacci(5) == 5, "6.1: Non-tail recursive Fibonacci - fib(5)")
assert_wrap(fibonacci(10) == 55, "6.2: Non-tail recursive Fibonacci - fib(10)")

// ============================================================================
// TEST 7: Tail Call to Different Function
// ============================================================================
print("--- [7] Tail Call to Different Function ---")

func helper(n, acc) {
    if (n <= 0) {
        return acc
    }
    return helper(n - 1, acc + n)
}

func caller(n) {
    return helper(n, 0)
}

assert_wrap(caller(10) == 55, "7.1: Tail call to different function - sum 1 to 10")
assert_wrap(caller(20) == 210, "7.2: Tail call to different function - sum 1 to 20")

// ============================================================================
// TEST 8: GCD with Tail Recursion
// ============================================================================
print("--- [8] GCD with Tail Recursion ---")

func gcd(a, b) {
    if (b == 0) {
        return a
    }
    return gcd(b, a % b)
}

assert_wrap(gcd(48, 18) == 6, "8.1: GCD tail recursion - gcd(48, 18)")
assert_wrap(gcd(100, 35) == 5, "8.2: GCD tail recursion - gcd(100, 35)")

// ============================================================================
// TEST 9: Collatz Sequence
// ============================================================================
print("--- [9] Collatz Sequence ---")

func collatz(n, steps) {
    if (n == 1) {
        return steps
    }
    if (n % 2 == 0) {
        return collatz(n / 2, steps + 1)
    }
    return collatz(n * 3 + 1, steps + 1)
}

assert_wrap(collatz(10, 0) == 6, "9.1: Collatz sequence - 10")
assert_wrap(collatz(27, 0) == 111, "9.2: Collatz sequence - 27")

// ============================================================================
// TEST 10: Deep Recursion with Closure
// ============================================================================
print("--- [10] Deep Recursion with Closure ---")

func makeRecursive(factor) {
    func recurse(n, acc) {
        if (n <= 0) {
            return acc
        }
        return recurse(n - 1, acc + factor)
    }
    return recurse
}

var r = makeRecursive(3)
assert_wrap(r(100, 0) == 300, "10.1: Deep recursion with closure - 100 * 3")
assert_wrap(r(500, 0) == 1500, "10.2: Deep recursion with closure - 500 * 3")

// ============================================================================
// TEST 11: Tail Recursive Power
// ============================================================================
print("--- [11] Tail Recursive Power ---")

func power(base, exp, acc) {
    if (exp <= 0) {
        return acc
    }
    return power(base, exp - 1, acc * base)
}

assert_wrap(power(2, 10, 1) == 1024, "11.1: Tail recursive power - 2^10")
assert_wrap(power(3, 5, 1) == 243, "11.2: Tail recursive power - 3^5")

// ============================================================================
// TEST 12: Simple Tail Recursion
// ============================================================================
print("--- [12] Simple Tail Recursion ---")

func process(n) {
    if (n <= 0) {
        return 42
    }
    return process(n - 1)
}

assert_wrap(process(100) == 42, "12.1: Simple tail recursion - 100 iterations")
assert_wrap(process(1000) == 42, "12.2: Simple tail recursion - 1000 iterations")

// ============================================================================
// TEST 13: Tail Recursion with List Building
// ============================================================================
print("--- [13] Tail Recursion with List ---")

func buildList(n, lst) {
    if (n <= 0) {
        return lst
    }
    lst[n - 1] = n
    return buildList(n - 1, lst)
}

var result = buildList(5, [0, 0, 0, 0, 0])
assert_wrap(result[0] == 1, "13.1: Tail recursion with list - first element")
assert_wrap(result[4] == 5, "13.2: Tail recursion with list - last element")

// ============================================================================
// TEST 14: Stress Test - Very Deep Recursion
// ============================================================================
print("--- [14] Stress Test - Deep Recursion ---")

func deepRecursion(n, acc) {
    if (n <= 0) {
        return acc
    }
    return deepRecursion(n - 1, acc + 1)
}

assert_wrap(deepRecursion(5000, 0) == 5000, "14.1: Stress test - 5000 iterations (no overflow)")

// ============================================================================
// TEST 15: Tail Call with Overloaded Function
// ============================================================================
print("--- [15] Tail Call with Overloaded Function ---")

func compute(n) {
    return n * 2
}

func compute(n, acc) {
    if (n <= 0) {
        return acc
    }
    return compute(n - 1, acc + n)
}

assert_wrap(compute(10, 0) == 55, "15.1: Tail call with overloaded function - sum 1 to 10")


// ============================================================================
// FINAL RESULTS
// ============================================================================
print("")
print("==========================================================")
print("TEST RESULTS")
print("==========================================================")
print("Tests Passed: %v", testsPassed)
print("Tests Failed: %v", testsFailed)
if (testsFailed == 0) {
    print("ALL TESTS PASSED!")
} else {
    print("SOME TESTS FAILED!")
}
print("==========================================================")