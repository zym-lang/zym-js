// ============================================================================
print("--- [30] Variadic Function Passed as Argument ---")

func applyVariadic(f) {
    return f(1, 2, 3)
}

var applied = applyVariadic(func(...args) {
    var total = 0
    for (var i = 0; i < length(args); i++) {
        total = total + args[i]
    }
    return total
})

assert_wrap(applied == 6, "30.1: Variadic func expr as argument")

// ============================================================================
// SECTION 31: VARIADIC IN DATA STRUCTURES
// ============================================================================
print("--- [31] Variadic Functions in Data Structures ---")

var fns = [
    func(...a) { return length(a) },
    func(...a) { return length(a) * 10 }
]

assert_wrap(fns[0](1, 2) == 2, "31.1: Variadic in list - first")
assert_wrap(fns[1](1, 2, 3) == 30, "31.2: Variadic in list - second")

var fnMap = {
    "count": func(...a) { return length(a) },
    "double": func(...a) { return length(a) * 2 }
}

assert_wrap(fnMap["count"](1, 2, 3) == 3, "31.3: Variadic in map - count")
assert_wrap(fnMap["double"](1, 2) == 4, "31.4: Variadic in map - double")

// ============================================================================
// SECTION 32: VARIADIC LAMBDA CLOSURES
// ============================================================================
print("--- [32] Variadic Lambda Closures ---")

func makeVarLambda(multiplier) {
    return func(...args) {
        var total = 0
        for (var i = 0; i < length(args); i++) {
            total = total + args[i]
        }
        return total * multiplier
    }
}

var vl2 = makeVarLambda(2)
var vl3 = makeVarLambda(3)
assert_wrap(vl2(1, 2, 3) == 12, "32.1: Variadic lambda closure x2")
assert_wrap(vl3(1, 2, 3) == 18, "32.2: Variadic lambda closure x3")
assert_wrap(vl2(10) == 20, "32.3: Variadic lambda closure single arg")

// ============================================================================
// SECTION 33: VARIADIC ARROW CLOSURES
// ============================================================================
print("--- [33] Variadic Arrow Closures ---")

func makeArrowVar(offset) {
    return (...args) => {
        var total = offset
        for (var i = 0; i < length(args); i++) {
            total = total + args[i]
        }
        return total
    }
}

var av1 = makeArrowVar(100)
assert_wrap(av1() == 100, "33.1: Arrow closure no args")
assert_wrap(av1(1, 2, 3) == 106, "33.2: Arrow closure with args")

// ============================================================================
// SECTION 34: RECURSIVE VARIADIC
// ============================================================================
print("--- [34] Recursive with Variadic ---")

func recursiveSum(...args) {
    if (length(args) == 0) return 0
    if (length(args) == 1) return args[0]
    return args[0] + recursiveSum(args[1])
}

assert_wrap(recursiveSum() == 0, "34.1: Recursive variadic empty")
assert_wrap(recursiveSum(5) == 5, "34.2: Recursive variadic single")
assert_wrap(recursiveSum(3, 7) == 10, "34.3: Recursive variadic two")

