    return rest
}

var r16 = arrowMixed(1, 2, 3, 4, 5)
assert_wrap(length(r16) == 3, "16.1: Arrow fixed+rest length")
assert_wrap(r16[0] == 3, "16.2: Arrow fixed+rest first")
