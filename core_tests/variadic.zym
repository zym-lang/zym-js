// ============================================================================
// SECTION 25: DISPATCHER RETURNING VARIADIC
// ============================================================================
print("--- [25] Dispatcher Returning Variadic ---")

func makeVariadicDispatcher() {
    func handler(x) { return x * 2 }
    func handler(x, y) { return x + y }
    func handler(...args) { return length(args) * 100 }
    return handler
}

var disp = makeVariadicDispatcher()
assert_wrap(disp(5) == 10, "25.1: Dispatcher exact 1 arg")
assert_wrap(disp(3, 7) == 10, "25.2: Dispatcher exact 2 args")
assert_wrap(disp() == 0, "25.3: Dispatcher variadic 0 args")
assert_wrap(disp(1, 2, 3) == 300, "25.4: Dispatcher variadic 3 args")
assert_wrap(disp(1, 2, 3, 4) == 400, "25.5: Dispatcher variadic 4 args")

// ============================================================================
// SECTION 26: DISPATCHER VARIADIC WITH CLOSURES
// ============================================================================
print("--- [26] Dispatcher Variadic with Closures ---")

func makeStatefulDispatcher(base) {
    var count = 0

    func op() {
        count = count + 1
        return base + count
    }

    func op(x) {
        count = count + x
        return base + count
    }

    func op(...args) {
        for (var i = 0; i < length(args); i++) {
            count = count + args[i]
        }
        return base + count
    }

    return op
}

var sd = makeStatefulDispatcher(100)
assert_wrap(sd() == 101, "26.1: Stateful dispatcher 0 args")
assert_wrap(sd(5) == 106, "26.2: Stateful dispatcher 1 arg")
assert_wrap(sd(1, 2, 3) == 112, "26.3: Stateful dispatcher variadic")
assert_wrap(sd() == 113, "26.4: Stateful dispatcher state persists")

// ============================================================================
// SECTION 27: MULTIPLE DISPATCHERS WITH VARIADIC
// ============================================================================
print("--- [27] Multiple Independent Variadic Dispatchers ---")

var sd1 = makeStatefulDispatcher(0)
var sd2 = makeStatefulDispatcher(1000)

assert_wrap(sd1(10) == 10, "27.1: Independent dispatcher 1")
assert_wrap(sd2(10) == 1010, "27.2: Independent dispatcher 2")
assert_wrap(sd1(1, 2) == 13, "27.3: Dispatcher 1 variadic")
assert_wrap(sd2(1, 2) == 1013, "27.4: Dispatcher 2 variadic")

