// SECTION 35: VARIADIC RETURNING VARIADIC
// ============================================================================
print("--- [35] Variadic Returning Variadic ---")

func wrapInVariadic() {
    func inner(...args) {
        return args
    }
    return inner
}

var wrapped = wrapInVariadic()
var r35 = wrapped(1, 2, 3)
assert_wrap(length(r35) == 3, "35.1: Wrapped variadic length")
assert_wrap(r35[0] == 1, "35.2: Wrapped variadic first")

// ============================================================================
// SECTION 36: VARIADIC WITH EARLY RETURN
// ============================================================================
print("--- [36] Variadic with Early Return ---")

func earlyReturn(...args) {
    if (length(args) == 0) return "empty"
    if (length(args) == 1) return "single"
    if (length(args) > 5) return "too many"
    return "normal"
}

assert_wrap(earlyReturn() == "empty", "36.1: Early return empty")
assert_wrap(earlyReturn(1) == "single", "36.2: Early return single")
assert_wrap(earlyReturn(1, 2) == "normal", "36.3: Early return normal")
assert_wrap(earlyReturn(1, 2, 3, 4, 5, 6) == "too many", "36.4: Early return too many")

// ============================================================================
// SECTION 37: VARIADIC OVERLOAD PRIORITY
// ============================================================================
print("--- [37] Variadic Overload Priority ---")

func priority() { return "zero" }
func priority(a) { return "one" }
func priority(a, b) { return "two" }
func priority(a, b, c) { return "three" }
func priority(...args) { return "variadic:" + str(length(args)) }

assert_wrap(priority() == "zero", "37.1: Priority 0 args - exact match wins")
assert_wrap(priority(1) == "one", "37.2: Priority 1 arg - exact match wins")
assert_wrap(priority(1, 2) == "two", "37.3: Priority 2 args - exact match wins")
assert_wrap(priority(1, 2, 3) == "three", "37.4: Priority 3 args - exact match wins")
assert_wrap(priority(1, 2, 3, 4) == "variadic:4", "37.5: Priority 4 args - variadic")
assert_wrap(priority(1, 2, 3, 4, 5) == "variadic:5", "37.6: Priority 5 args - variadic")

// ============================================================================
// SECTION 38: VARIADIC ONLY (NO FIXED OVERLOADS)
// ============================================================================
print("--- [38] Variadic Only - No Fixed Overloads ---")

func varOnly(...args) {
    return length(args)
}

assert_wrap(varOnly() == 0, "38.1: Variadic only 0 args")
assert_wrap(varOnly(1) == 1, "38.2: Variadic only 1 arg")
assert_wrap(varOnly(1, 2) == 2, "38.3: Variadic only 2 args")
assert_wrap(varOnly(1, 2, 3, 4, 5) == 5, "38.4: Variadic only 5 args")

// ============================================================================
// SECTION 39: SHARED UPVALUES WITH VARIADIC SIBLING CLOSURES
// ============================================================================
print("--- [39] Shared Upvalues with Variadic Siblings ---")

var varGetter
var varAdder

func setupVarShared() {
    var total = 0

    varGetter = func() {
        return total
    }

    varAdder = func(...nums) {
        for (var i = 0; i < length(nums); i++) {
            total = total + nums[i]
        }
        return total
    }
}

setupVarShared()
assert_wrap(varGetter() == 0, "39.1: Initial shared state")
assert_wrap(varAdder(1, 2, 3) == 6, "39.2: Variadic adds to shared")
assert_wrap(varGetter() == 6, "39.3: Getter sees variadic changes")
assert_wrap(varAdder(4) == 10, "39.4: Add more")
assert_wrap(varGetter() == 10, "39.5: Getter confirms")

// ============================================================================
// SECTION 40: VARIADIC DISPATCHER IN DATA STRUCTURES
// ============================================================================
print("--- [40] Variadic Dispatcher in Data Structures ---")

func makeVarDisp() {
    func fn(x) { return x }
    func fn(...args) { return length(args) * 100 }
    return fn
}

var dispList = [makeVarDisp(), makeVarDisp()]
assert_wrap(dispList[0](42) == 42, "40.1: Dispatcher in list exact match")
assert_wrap(dispList[0](1, 2, 3) == 300, "40.2: Dispatcher in list variadic")
assert_wrap(dispList[1](7) == 7, "40.3: Second dispatcher exact")

// ============================================================================
// SECTION 41: VARIADIC DISPATCHER PASSED AS ARGUMENT
// ============================================================================
print("--- [41] Variadic Dispatcher as Argument ---")

func useDispatcher(f) {
    var r1 = f(10)
    var r2 = f(1, 2, 3)
    return r1 + r2
}

var dispResult = useDispatcher(makeVarDisp())
assert_wrap(dispResult == 310, "41.1: Dispatcher as argument (10 + 300)")

// ============================================================================
// SECTION 42: VARIADIC DISPATCHER REASSIGNMENT
// ============================================================================
print("--- [42] Variadic Dispatcher Reassignment ---")

var d42 = makeVarDisp()
var d42b = d42
var d42c = d42b

assert_wrap(d42(5) == 5, "42.1: Original dispatcher")
assert_wrap(d42b(1, 2) == 200, "42.2: First reassignment")
assert_wrap(d42c(7) == 7, "42.3: Second reassignment exact")
assert_wrap(d42c(1, 2, 3, 4) == 400, "42.4: Second reassignment variadic")

// ============================================================================
// SECTION 43: DEEPLY NESTED VARIADIC WITH CLOSURES
// ============================================================================
print("--- [43] Deeply Nested Variadic with Closures ---")

func deepVar() {
    var a = 1
    func level2() {
        var b = 10
        func level3() {
            var c = 100
            func varInner(...args) {
                var sum = a + b + c
                for (var i = 0; i < length(args); i++) {
                    sum = sum + args[i]
                }
                return sum
            }
            return varInner
        }
        return level3
    }
    return level2
}

var dv1 = deepVar()
var dv2 = dv1()
var dv3 = dv2()
assert_wrap(dv3() == 111, "43.1: Deep nested variadic no args")
assert_wrap(dv3(1, 2, 3) == 117, "43.2: Deep nested variadic with args")

// ============================================================================
// SECTION 44: VARIADIC OVERLOAD FACTORY PATTERN
// ============================================================================
print("--- [44] Variadic Overload Factory ---")

func makeProcessor() {
    var state = 0

    func process() { return state }
    func process(x) { state = x; return state }
    func process(...args) {
        state = 0
        for (var i = 0; i < length(args); i++) {
            state = state + args[i]
        }
        return state
    }

    return process
}

var proc = makeProcessor()
assert_wrap(proc() == 0, "44.1: Factory initial state")
assert_wrap(proc(42) == 42, "44.2: Factory set single")
assert_wrap(proc() == 42, "44.3: Factory get after set")
assert_wrap(proc(1, 2, 3) == 6, "44.4: Factory variadic set")
assert_wrap(proc() == 6, "44.5: Factory get after variadic")

// ============================================================================
// SECTION 45: MIXED FUNCTION TYPES WITH VARIADIC
// ============================================================================
print("--- [45] Mixed Function Types with Variadic ---")

func mixedTypes() {
    func named(...args) { return length(args) * 1 }

    var anon = func(...args) { return length(args) * 10 }

    var arrow = (...args) => { return length(args) * 100 }

    var r1 = named(1, 2)
    var r2 = anon(1, 2, 3)
    var r3 = arrow(1, 2, 3, 4)

    if (r1 == 2) { testsPassed = testsPassed + 1
    } else { testsFailed = testsFailed + 1; print("FAILED: 45.1: Named variadic"); print("") }

    if (r2 == 30) { testsPassed = testsPassed + 1
    } else { testsFailed = testsFailed + 1; print("FAILED: 45.2: Anon variadic"); print("") }

    if (r3 == 400) { testsPassed = testsPassed + 1
    } else { testsFailed = testsFailed + 1; print("FAILED: 45.3: Arrow variadic"); print("") }
}

mixedTypes()

// ============================================================================
// SECTION 46: VARIADIC WITH CONDITIONAL LOGIC
// ============================================================================
print("--- [46] Variadic with Conditional Logic ---")

func classify(...args) {
    var n = length(args)
    if (n == 0) return "none"
    if (n == 1) return "one"
    if (n == 2) return "pair"
    if (n <= 5) return "few"
    return "many"
}

assert_wrap(classify() == "none", "46.1: Classify none")
assert_wrap(classify(1) == "one", "46.2: Classify one")
assert_wrap(classify(1, 2) == "pair", "46.3: Classify pair")
assert_wrap(classify(1, 2, 3) == "few", "46.4: Classify few")
assert_wrap(classify(1, 2, 3, 4, 5, 6) == "many", "46.5: Classify many")

// ============================================================================
// SECTION 47: VARIADIC + STRING OPERATIONS
// ============================================================================
print("--- [47] Variadic String Operations ---")

func joinWith(sep, ...parts) {
    if (length(parts) == 0) return ""
    var result = str(parts[0])
    for (var i = 1; i < length(parts); i++) {
        result = result + sep + str(parts[i])
    }
    return result
}

assert_wrap(joinWith("-", 1, 2, 3) == "1-2-3", "47.1: Join with dash")
assert_wrap(joinWith(", ", "a", "b") == "a, b", "47.2: Join with comma")
assert_wrap(joinWith("-") == "", "47.3: Join empty parts")

// ============================================================================
// SECTION 48: VARIADIC DISPATCHER CHAIN
// ============================================================================
print("--- [48] Variadic Dispatcher Chain ---")

func chainFactory() {
    func stage1() {
        func inner(x) { return x * 2 }
        func inner(...args) { return length(args) * 100 }
        return inner
    }

    func stage1(offset) {
        func inner(x) { return x + offset }
        func inner(...args) { return length(args) + offset }
        return inner
    }

    return stage1
}

var chain = chainFactory()
var c1 = chain()
var c2 = chain(50)

assert_wrap(c1(5) == 10, "48.1: Chain stage1() exact")
assert_wrap(c1(1, 2, 3) == 300, "48.2: Chain stage1() variadic")
assert_wrap(c2(5) == 55, "48.3: Chain stage1(50) exact")
assert_wrap(c2(1, 2, 3) == 53, "48.4: Chain stage1(50) variadic")

// ============================================================================
// SECTION 49: VARIADIC WITH REST PARAM AS LIST OPERATIONS
// ============================================================================
print("--- [49] Rest Param List Operations ---")

func firstArg(...args) {
    if (length(args) == 0) return null
    return args[0]
}

func lastArg(...args) {
    if (length(args) == 0) return null
    return args[length(args) - 1]
}

assert_wrap(firstArg(10, 20, 30) == 10, "49.1: First arg")
assert_wrap(lastArg(10, 20, 30) == 30, "49.2: Last arg")
assert_wrap(firstArg() == null, "49.3: First arg empty")
assert_wrap(lastArg() == null, "49.4: Last arg empty")

// ============================================================================
// SECTION 50: ULTIMATE COMPREHENSIVE VARIADIC TEST
// ============================================================================
print("--- [50] Ultimate Comprehensive Variadic Test ---")

var ultGet
var ultProcess

func setupUltimate(base) {
    var state = base

    ultGet = func() { return state }

    func processor(x) {
        state = state + x
        return state
    }

    func processor(x, y) {
        state = state + x * y
        return state
    }

    func processor(...args) {
        for (var i = 0; i < length(args); i++) {
            state = state + args[i]
        }
        return state
    }

    ultProcess = processor
}

setupUltimate(100)
assert_wrap(ultGet() == 100, "50.1: Ultimate initial state")
assert_wrap(ultProcess(5) == 105, "50.2: Ultimate exact 1 arg")
assert_wrap(ultProcess(2, 3) == 111, "50.3: Ultimate exact 2 args (105 + 2*3)")
assert_wrap(ultProcess(1, 2, 3) == 117, "50.4: Ultimate variadic (111 + 1+2+3)")
assert_wrap(ultGet() == 117, "50.5: Ultimate state check")
assert_wrap(ultProcess() == 117, "50.6: Ultimate variadic 0 args no change")


