assert_wrap(r17[0] == 1, "17.2: Arrow direct return first")

// ============================================================================
// SECTION 18: VARIADIC WITH CLOSURES - CAPTURE OUTER VAR
// ============================================================================
print("--- [18] Variadic Closure Capture ---")

func makeCollector(prefix) {
    func collect(...items) {
        return prefix + ":" + str(length(items))
    }
    return collect
}

var collector = makeCollector("test")
assert_wrap(collector() == "test:0", "18.1: Variadic closure 0 args")
assert_wrap(collector(1) == "test:1", "18.2: Variadic closure 1 arg")
assert_wrap(collector(1, 2, 3) == "test:3", "18.3: Variadic closure 3 args")

// ============================================================================
// SECTION 19: VARIADIC WITH CLOSURES - MUTATING STATE
// ============================================================================
print("--- [19] Variadic Closure Mutating State ---")

func makeAccumulator() {
    var total = 0
    func addAll(...nums) {
        for (var i = 0; i < length(nums); i++) {
            total = total + nums[i]
        }
        return total
    }
    return addAll
}

var acc = makeAccumulator()
assert_wrap(acc(1, 2, 3) == 6, "19.1: Accumulator first call")
assert_wrap(acc(4, 5) == 15, "19.2: Accumulator second call")
assert_wrap(acc(10) == 25, "19.3: Accumulator third call")
assert_wrap(acc() == 25, "19.4: Accumulator no args unchanged")

// ============================================================================
// SECTION 20: VARIADIC IN NESTED CLOSURES
// ============================================================================
print("--- [20] Variadic in Nested Closures ---")

func outerNested(x) {
    func middleNested(y) {
        func innerVariadic(...args) {
            var sum = x + y
            for (var i = 0; i < length(args); i++) {
                sum = sum + args[i]
            }
            return sum
        }
        return innerVariadic
    }
    return middleNested
}

var n1 = outerNested(10)
var n2 = n1(20)
assert_wrap(n2() == 30, "20.1: Nested variadic no extra args")
assert_wrap(n2(5) == 35, "20.2: Nested variadic 1 extra arg")
assert_wrap(n2(1, 2, 3) == 36, "20.3: Nested variadic 3 extra args")

// ============================================================================
// SECTION 21: VARIADIC + OVERLOAD IN NESTED SCOPE
// ============================================================================
print("--- [21] Variadic + Overload in Nested Scope ---")

func nestedOverloadScope() {
    func handler(x) { return x * 2 }
    func handler(x, y) { return x + y }
    func handler(...args) {
        var total = 0
        for (var i = 0; i < length(args); i++) {
            total = total + args[i]
        }
        return total * 10
    }

    var r1 = handler(5)
    var r2 = handler(3, 7)
    var r3 = handler(1, 2, 3)
    var r4 = handler()

    if (r1 == 10) { testsPassed = testsPassed + 1
    } else { testsFailed = testsFailed + 1; print("FAILED: 21.1: Nested exact 1 arg"); print("") }

    if (r2 == 10) { testsPassed = testsPassed + 1
    } else { testsFailed = testsFailed + 1; print("FAILED: 21.2: Nested exact 2 args"); print("") }

    if (r3 == 60) { testsPassed = testsPassed + 1
    } else { testsFailed = testsFailed + 1; print("FAILED: 21.3: Nested variadic 3 args"); print("") }

    if (r4 == 0) { testsPassed = testsPassed + 1
    } else { testsFailed = testsFailed + 1; print("FAILED: 21.4: Nested variadic 0 args"); print("") }
}

nestedOverloadScope()

