// ============================================================================
// SECTION 29: VARIADIC ITERATION PATTERNS
// ============================================================================
print("--- [29] Variadic Iteration Patterns ---")

func sumAll(...nums) {
    var total = 0
    for (var i = 0; i < length(nums); i++) {
        total = total + nums[i]
    }
    return total
}

assert_wrap(sumAll() == 0, "29.1: Sum empty")
assert_wrap(sumAll(5) == 5, "29.2: Sum single")
assert_wrap(sumAll(1, 2, 3, 4, 5) == 15, "29.3: Sum many")

func findMax(...nums) {
    var max = nums[0]
    for (var i = 1; i < length(nums); i++) {
        if (nums[i] > max) {
            max = nums[i]
        }
    }
    return max
}

assert_wrap(findMax(3, 1, 4, 1, 5, 9) == 9, "29.4: Find max")
assert_wrap(findMax(42) == 42, "29.5: Find max single")

